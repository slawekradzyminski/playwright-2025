{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "config/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "httpclients/**/*.ts",
    "generators/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.ts"
  ]
}
