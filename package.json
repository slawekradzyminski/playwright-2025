{
  "name": "test-automation-in-practice-2025",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test tests/api/ --project=client-tests",
    "test:api:admin": "playwright test --config=playwright.admin.config.ts --project=admin-api",
    "test:api:all": "npm run test:api && npm run test:api:admin",
    "test:ui": "playwright test tests/ui/ --project=client-tests",
    "test:ui:admin": "playwright test --config=playwright.admin.config.ts --project=admin-ui",
    "test:ui:all": "npm run test:ui && npm run test:ui:admin",
    "test:admin": "playwright test --config=playwright.admin.config.ts",
    "test:all": "npm run test:api && npm run test:ui && npm run test:admin",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check . --write --unsafe && tsc --noEmit",
    "check:ci": "npm run typecheck && npm run check && npm test",
    "traffic:logs": "node scripts/traffic-logs.mjs"
  },
  "keywords": [
    "playwright",
    "testing",
    "typescript",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "description": "A modern TypeScript-based test suite for validating both API and UI layers of a Dockerized AWS-like application stack",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  }
}
