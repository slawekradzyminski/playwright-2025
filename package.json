{
  "name": "test-automation-in-practice-2025",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --grep @api",
    "test:ui": "playwright test --grep @ui",
    "allure:clean": "rm -rf allure-results allure-report",
    "allure:generate": "allure generate allure-results --output allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "trace:test": "playwright test --trace on",
    "trace:open": "playwright show-trace \"$(find test-results -name trace.zip -print0 | xargs -0 ls -t | head -n 1)\"",
    "trace:clean": "rm -rf test-results playwright-report"
  },
  "keywords": [
    "playwright",
    "testing",
    "typescript",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "description": "A modern TypeScript-based test suite for validating both API and UI layers of a Dockerized AWS-like application stack",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "allure": "^3.5.0",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.4.2"
  }
}
